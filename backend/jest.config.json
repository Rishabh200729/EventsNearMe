{
  "preset": "ts-jest/presets/default-esm",
  "testEnvironment": "node",
  "extensionsToTreatAsEsm": [".ts"],
  "moduleNameMapper": {
    "^(\\./.*)\\.js$": "$1",
    "^(\\../.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "useESM": true,
        "tsconfig": "tsconfig.json"
      }
    ]
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/app.ts",
    "!src/tests/**"
  ],
  "testMatch": [
    "<rootDir>/src/tests/**/*.test.ts"
  ],
  "setupFilesAfterEnv": ["<rootDir>/src/tests/setup.ts"],
  "testTimeout": 10000
}